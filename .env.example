# IMPORTANT for an internet-facing deployment:
#   - Set SECRET_KEY to a long random string (e.g. `openssl rand -hex 32`).
#   - Change ADMIN_PASSWORD from the default below.
#   - Set SESSION_COOKIE_SECURE=true once you are serving over HTTPS.
#   - Run behind HTTPS and start uvicorn with --proxy-headers so per-IP
#     rate limiting sees the real client address, not your reverse proxy.
SECRET_KEY=change-this-to-a-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_MOBILE=9999999999
DATABASE_PATH=data/gramseva.db

# Send the session cookie only over HTTPS. Keep false for local http dev.
SESSION_COOKIE_SECURE=false

# Optional: auto-load users from this CSV on startup (skips existing users).
# Holds personal data + passwords, so it is gitignored. Leave the default
# and drop a users.csv in the project root, or point this elsewhere.
SEED_USERS_CSV=users.csv

# Server (used by start.py / run.py)
HOST=127.0.0.1
PORT=8000

# Village branding (white-label)
VILLAGE_NAME=Barloni
APP_NAME=Gram Seva
# Logo mark (emoji) and footer tagline.
BRAND_EMOJI=🏛️
BRAND_TAGLINE=A village civic platform · Built for the community
# Theme colours (hex; invalid values fall back to defaults).
BRAND_PRIMARY=#1a365d
BRAND_ACCENT=#2f855a

# Complaints: the wards/areas residents can pick from (comma-separated).
COMPLAINT_WARDS=Ward 1,Ward 2,Ward 3,Ward 4,Ward 5
