SECRET_KEY=change-this-to-a-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_MOBILE=9999999999
DATABASE_PATH=data/gramseva.db

# Optional: auto-load users from this CSV on startup (skips existing users).
# Holds personal data + passwords, so it is gitignored. Leave the default
# and drop a users.csv in the project root, or point this elsewhere.
SEED_USERS_CSV=users.csv

# Server (used by start.py / run.py)
HOST=127.0.0.1
PORT=8000

# Village branding (white-label)
VILLAGE_NAME=Barloni
APP_NAME=Gram Seva
